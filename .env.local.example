# ============================================================
# Configuracao do ambiente — Estudio Lidiane Carvalho
# Copie este arquivo para ".env.local" e preencha os valores.
# ============================================================

# --- Supabase (banco de dados + autenticacao) ---
# Crie um projeto gratis em https://supabase.com e copie em Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-anon-key-publica
SUPABASE_SERVICE_ROLE_KEY=sua-service-role-key-secreta

# --- Negocio ---
NEXT_PUBLIC_WHATSAPP_NUMERO=5585981933902
NEXT_PUBLIC_STUDIO_NOME=Lidiane Carvalho
NEXT_PUBLIC_STUDIO_ENDERECO=R. 12, 148 - Lot. Sol Nascente, Aquiraz - CE, 61700-000
NEXT_PUBLIC_MAPS_URL=https://www.google.com/maps/place/Lidiane+Carvalho+-+Estudio+de+Beleza
NEXT_PUBLIC_INSTAGRAM_URL=https://instagram.com/lidianecarvalho

# --- Automacoes / Cron (CRM) ---
# Segredo usado para proteger as rotas de cron (gere uma string aleatoria)
CRON_SECRET=troque-por-uma-string-aleatoria-segura

# Numero de dias de inatividade que dispara a mensagem de reativacao
REATIVACAO_DIAS=20
